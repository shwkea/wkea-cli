{
  "name": "wkea-manage-cli",
  "version": "1.0.47",
  "description": "WKEA 后台管理 CLI 工具",
  "main": "dist/index.js",
  "bin": {
    "wkea-manage-cli": "./dist/index.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:mysql2 && node -e \"require('fs').cpSync('docs','dist/docs',{recursive:true})\"",
    "pack": "node scripts/pack.js",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\" && exit 0",
    "link": "npm run build && npm link"
  },
  "keywords": [
    "wkea",
    "cli",
    "vendor"
  ],
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.7",
    "commander": "^12.0.0",
    "cos-nodejs-sdk-v5": "^3.0.0",
    "inquirer": "^9.3.8",
    "marked": "^18.0.4",
    "node-ssh": "^13.2.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.5",
    "esbuild": "^0.28.0",
    "mysql2": "^3.22.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
